{
    "name": "investsmart",
    "version": "1.0.0",
    "description": "InvestSmart - Plataforma de análise de investimentos da B3",
    "private": true,
    "scripts": {
        "dev": "concurrently -k -p \"[{name}]\" -n \"FRONTEND,BACKEND\" -c \"cyan,yellow\" \"npm run dev --prefix ./frontend\" \"npm run dev --prefix ./backend\"",
        "dev:frontend": "npm run dev --prefix ./frontend",
        "dev:backend": "npm run dev --prefix ./backend",
        "install:all": "npm install && npm install --prefix ./frontend && npm install --prefix ./backend",
        "build": "npm run build --prefix ./frontend"
    },
    "devDependencies": {
        "concurrently": "^9.1.2"
    }
}