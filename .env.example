# InvestSmart Environment Variables
# Copie este arquivo para .env e preencha com seus valores reais

# Backend
PORT=3001
NODE_ENV=development

# BRAPI - https://brapi.dev
BRAPI_TOKEN=your_brapi_token_here

# Supabase - https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Frontend (Vite) - prefixo VITE_ obrigatório
VITE_API_URL=http://localhost:3001
VITE_BRAPI_TOKEN=your_brapi_token_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here
